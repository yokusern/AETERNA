### Project GearMaster - Production Config Template

# --- WordPress REST API Settings ---
WP_BASE_URL=https://your-site-url.com
WP_USERNAME=your-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# 安全装置: true の間は実際の投稿は行われず、data/wp_payloads に保存されます。
WP_DRY_RUN=true

# 投稿設定
WP_POST_STATUS=draft
WP_DEFAULT_CATEGORY=ガジェット
WP_FEATURED_MEDIA_ID=

# --- AI Engine Settings ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Affiliate Tracking IDs ---
AMAZON_ASSOCIATE_ID=your-amazon-id-22
RAKUTEN_AFFILIATE_ID=your-rakuten-id
A8_TRACKING_ID=your-a8-id

# Optionals
GEARMASTER_CONFIG=config/config.yml

# Future connectors
GOOGLE_SEARCH_CONSOLE_PROPERTY=https://your-site-url.com
GOOGLE_APPLICATION_CREDENTIALS=google-credentials-key.json